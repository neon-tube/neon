/target/
# `verify/` is a detached workspace, so it builds into its own tree.
/verify/target/
/runtime/build/
/runtime/build-tests/
/runtime/models/build/
_neon/
compile_flags.txt
.DS_Store

# Benchmark build outputs. Every language in bench/ compiles into its own tree
# (dotnet's `bin`/`obj` alone is ~90MB) and none of it is source.
bench/**/bin/
bench/**/obj/
bench/**/build/
bench/**/target/
bench/**/classes/
# One binary per benchmark, named for the benchmark, in whichever language dir
# compiled it. No source file shares these names, so the wildcard is safe and
# saves editing this list every time a language is added.
bench/*/*/bf
bench/*/*/bt
bench/*/*/wf
bench/*/*/nb
bench/*/*/bf_native
bench/*/*/bt_native
bench/*/*/wf_native
bench/*/*/nb_native

# GHC and ocamlopt leave their intermediates beside the source.
bench/**/*.hi
bench/**/*.cmi
bench/**/*.cmx
bench/**/*.o

# Java compiles in place — no bin/ dir to catch these.
bench/**/*.class

# The bench runner caches per-language results between runs.
bench/**/.bench_cache.json
