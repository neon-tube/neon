// A catch body is an ordinary expression, so it may itself throw — translating
// one error kind into another. `main` catches the translated error, proving both
// catches ran and that the second saw the *new* error, not the original.

use std::io;
use std::string;

record LowError { msg: str }
record HighError { msg: str }

impl Display for LowError {
    fn to_string(error: LowError) -> str { error.msg }
}
impl Error for LowError {}

impl Display for HighError {
    fn to_string(error: HighError) -> str { error.msg }
}
impl Error for HighError {}

fn low() throws LowError -> i64 {
    throw LowError { msg: "cable unplugged" }
}

fn high() throws HighError -> i64 {
    try low() catch (e) {
        io::println("translating");
        throw HighError { msg: string::concat("wrapped: ", to_string(e)) }
    }
}

fn main() {
    let v = try high() catch (e) {
        io::println(to_string(e));
        -1
    };
    io::println(to_string(v));
}
