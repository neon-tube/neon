//@ compile-fail
//@ error-contains: any
//
// `any` is opaque, not a free pass: nothing may be done with it until it is
// narrowed. Using one as an i64 without an `as` is a type error, so erasure
// stays honest — the cast is the receipt.

use std::io;
use std::string;

fn add_one(v: any) -> i64 { v + 1 }

fn main() {
    io::println(string::int_to_str(add_one(41)));
}
