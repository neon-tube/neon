//@ exit: 101

// The cast triad: `as` is for casts that cannot fail; a fallible cast must say what a
// mismatch does. `as? T` tests and yields `T | null`, composing with `orelse`; `as! T`
// asserts and TRAPS on mismatch (exit 101), the `try`/`try?`/`try!` discipline applied to
// casts. Bare `as` on a fallible cast is a compile error -- pinned in
// bare_cast_must_be_infallible.neon -- but stays legal wherever the checker can prove
// success: widening, newtype bridges, and uses refined by narrowing (the `w is i64` guard
// below).
use std::io;

record A { x: i64 }
record B { y: i64 }

fn main() {
    // as? on any: hit and miss.
    let a: any = 42;
    io::println(to_string((a as? i64) orelse -1));
    io::println(to_string((a as? str) orelse "miss"));

    // as? on a union: hit and miss.
    let u: A | B = A { x: 5 };
    let hit = u as? A;
    if hit != null { io::println(to_string(hit.x)); }
    let miss = u as? B;
    io::println(to_string(miss == null));

    // as! success paths.
    let n: i64 | str = 7;
    io::println(to_string(n as! i64));
    let back: any = "boxed";
    io::println(back as! str);

    // bare as stays for infallible: widening + erasure round trip via narrowing.
    let w: i64 | str = 3;
    if w is i64 { io::println(to_string(w + 1)); }

    io::println("before trap");
    // as! failure: traps with exit 101.
    io::println(to_string(n as! str));
    io::println("unreachable");
}
