// Tags are canonical: a function of the value's concrete type, not of the static type at
// the erasure site. A member of a union erased into `any` — whether the union was erased
// directly or widened back at a match join — carries the MEMBER's tag, and answers `is`
// and `as` exactly as a directly-erased value does.
//
// This pins the join case: the match arms below narrow to the concrete types, the join re-
// widens to `A | B`, and the erasure at `ret` used to stamp `type_tag(A | B)` — so
// `e(A{..}) is A` answered false on a value that was exactly an `A`, and under checked
// casts `as` would have falsely trapped. Canonical tags are the invariant every checked
// cast rests on: a box's tag proves what was genuinely constructed.
//
// The union-typed cast out of `any` is the companion direction: no box carries a union
// tag, so `back as A | B` is a membership test over the members' tags, injecting the one
// that matches.

use std::io;

record A { x: i64 }
record B { y: i64 }

fn through_join(v: A | B) -> any {
    match v {
        is A => v as A,
        is B => v as B,
    }
}

fn direct(v: A | B) -> any { v }

fn main() {
    let p = through_join(A { x: 1 });
    io::println(to_string(p is A));
    io::println(to_string(p is B));

    let q = direct(B { y: 2 });
    io::println(to_string(q is B));
    io::println(to_string(q is A));

    // Recovery reads the member back out at its own type.
    io::println(to_string((p as! A).x));
    io::println(to_string((q as! B).y));

    // And the union-typed recovery injects the matching member.
    let u = p as! A | B;
    match u {
        is A => io::println("still A"),
        is B => io::println("became B?!"),
    }
}
