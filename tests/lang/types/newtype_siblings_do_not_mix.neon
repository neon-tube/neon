//@ compile-fail
//@ error-contains: Meter
//
// Two newtypes over the SAME representation are still different types. This is
// the whole reason to reach for one: `Second` cannot be passed as `Meter` even
// though both are `f64` underneath.

use std::io;
use std::string;

newtype Meter = f64
newtype Second = f64

fn show(d: Meter) -> str { string::float_to_str(d as f64) }

fn main() {
    let s = 10.0 as Second;
    io::println(show(s));
}
