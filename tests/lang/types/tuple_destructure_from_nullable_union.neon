// Destructuring a tuple out of a `(tuple) | null` return after an `is null` guard. This
// used to fail the C compile -- the destructure read `._0`/`._1` off the union struct,
// which has no tuple members -- and the workaround was returning a two-field record
// instead. Fixed by the narrowing work: the guarded `r` is refined to the tuple and the
// value-side projection at the variable-use funnel hands the destructure a value at the
// tuple's own repr. Both branches pinned; the record shape was never broken and needs no
// pin.

use std::io;

fn uncons(empty: bool) -> (i64, str) | null {
    if empty { null } else { (65, "bc") }
}

fn main() {
    let r = uncons(false);
    if r is null {
        io::println("empty");
    } else {
        let (b, rest) = r;
        io::println(to_string(b));
        io::println(rest);
    }

    let e = uncons(true);
    if e is null {
        io::println("empty");
    } else {
        let (b, rest) = e;
        io::println(to_string(b));
    }
}
