// Comments: `//` to end of line, `/* */` block comments, and block comments
// nest — an inner `*/` closes only the inner one, so commenting out a region
// that already contains a block comment works.

use std::io;
use std::string;

/* A block comment
   spanning lines. */

/* Nested:
   /* inner */
   still a comment. */

fn show(v: i64) { io::println(string::int_to_str(v)); } // trailing comment

fn main() {
    show(1); // after a statement
    /* between */ show(2);
    show(/* inside a call */ 3);
    show(4 /* inside an expression */ + 5);

    // A comment containing what looks like code: show(999);
    // and one containing an unterminated string: "
    io::println("// not a comment");
    io::println("/* also not a comment */");
}
