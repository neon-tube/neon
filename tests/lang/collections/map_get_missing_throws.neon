// A map lookup that misses THROWS: `map::get` has signature
//
//     fn get[K, V](m: Map[K, V], k: K) throws KeyError -> V
//
// It never returns a sentinel and never fabricates a value — a missing key is
// distinguishable from a key whose value happens to be the zero of its type,
// because absence travels on the error channel, not in the value.
//
// That last point is the whole test: "zero" is stored under "zero", so a `get`
// that signalled absence in the value would make the two indistinguishable.
//
// Both idioms appear: `try?` + `orelse` for the easy path, and `try`/`catch`
// where the distinction matters.

use std::io;
use std::string;
use std::collections::map;

fn main() {
    let m: Map[str, i64] = map::set(map::set(map::new(), "zero", 0), "one", 1);

    // Present: `try?` softens the (unraised) error and `orelse` never fires.
    io::println(string::int_to_str(try? map::get(m, "one") orelse -1));

    // Present, and the value is 0 — not a miss. `catch` is not reached.
    try {
        io::println(string::concat("zero: ", string::int_to_str(map::get(m, "zero"))));
    } catch (e) {
        io::println("zero: MISSING");
    };

    // Absent: the throw is what reports it, and `catch` runs.
    try {
        io::println(string::concat("nope: ", string::int_to_str(map::get(m, "nope"))));
    } catch (e) {
        io::println("nope: MISSING");
    };

    // The easy path over the same miss: `try?` turns the error into null and
    // `orelse` supplies the default.
    io::println(string::int_to_str(try? map::get(m, "nope") orelse -1));

    // `contains` agrees with `get`, and does not throw either way.
    io::println(if map::contains(m, "zero") { "yes" } else { "no" });
    io::println(if map::contains(m, "nope") { "yes" } else { "no" });
}
