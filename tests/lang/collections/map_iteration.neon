// A `Map[K, V]` is not a `Mappable` — it is a functor over two parameters, not one
// — so it iterates through `map::keys`, which returns a `List[K]` you walk with a
// `for` loop, looking each value up as you go.
//
// Map iteration order is UNSPECIFIED — it follows the hash table, not insertion. So this
// golden asserts only order-independent facts: the number of entries, the sum of
// the values, and a per-key lookup. A test that printed entries in iteration order
// would be pinning an implementation detail, not the language.

use std::io;
use std::string;
use std::collections::list;
use std::collections::map;

fn main() {
    let m: Map[str, i64] = map::set(map::set(map::set(map::new(), "a", 1), "b", 2), "c", 3);

    let count = 0;
    let sum = 0;
    let key_bytes = 0;
    for k in map::keys(m) {
        // Every key `keys` hands back is really in the map, so the lookup cannot
        // miss; `try?`/`orelse` satisfies the type without a real fallback.
        let v = try? map::get(m, k) orelse -1;
        count = count + 1;
        sum = sum + v;
        key_bytes = key_bytes + string::byte_len(k);
    };

    io::println(string::concat("count: ", to_string(count)));
    io::println(string::concat("sum: ", to_string(sum)));
    io::println(string::concat("key bytes: ", to_string(key_bytes)));
    io::println(string::concat("keys: ", to_string(list::len(map::keys(m)))));

    // An empty map yields no keys: the `for` body never runs.
    let empty: Map[str, i64] = map::new();
    for k in map::keys(empty) {
        io::println("empty: yielded something");
    };
    io::println(string::concat("empty keys: ", to_string(list::len(map::keys(empty)))));
}
