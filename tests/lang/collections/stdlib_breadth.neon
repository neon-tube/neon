// The additions of 2026-07-19: splitting and trimming text, list and map queries, and
// numbers. Grouped in one program because each is small and the point is that they
// compose — `split` feeds `list::contains`, `lines` feeds `sum`.

use std::io;
use std::string;
use std::math;
use std::collections::list;
use std::collections::map;

fn main() {
    // `split` is the inverse of `join`, including at the edges: a separator at either end
    // yields an empty part there.
    io::println(string::join(string::split("a,b,c", ","), "|"));
    io::println(string::join(string::split(",a,", ","), "|"));
    io::println("#{list::len(string::split("abc", ","))}");
    io::println("#{list::len(string::split("a", ""))}");

    // `lines` drops one trailing newline and a CR before it.
    io::println(string::join(string::lines("a\nb\n"), "|"));
    io::println(string::join(string::lines("a\r\nb"), "|"));
    io::println("#{list::len(string::lines(""))}");

    io::println(string::concat("[", string::concat(string::trim("  hi \t"), "]")));
    io::println(string::replace("a-b-c", "-", "+"));
    // Non-overlapping, left to right: the second `a` is left over.
    io::println(string::replace("aaa", "aa", "b"));

    // List queries. `contains` compares structurally, so it works on any element type.
    io::println("#{list::contains([1, 2, 3], 2)} #{list::contains([1, 2, 3], 9)}");
    io::println("#{list::contains(["a", "b"], "b")}");
    io::println("#{list::index_of([5, 6, 7], 6) orelse -1}");
    io::println("#{list::index_of([5, 6, 7], 9) orelse -1}");
    io::println("#{list::first([1, 2]) orelse -1} #{list::last([1, 2]) orelse -1}");
    let empty: List[i64] = [];
    io::println("#{list::is_empty(empty)} #{list::first(empty) orelse -1}");
    io::println(string::join(list::reverse(["a", "b", "c"]), ""));
    io::println("#{list::sum([1, 2, 3])}");

    // Map queries. `remove` returns a new map; the original is untouched.
    let m = map::set(map::set(map::new(), "a", 1), "b", 2);
    io::println("#{map::get_or(m, "a", -1)} #{map::get_or(m, "z", -1)}");
    let r = map::remove(m, "a");
    io::println("#{map::len(r)} #{map::contains(r, "a")} #{map::len(m)}");
    // Removing an absent key is not an error: it already says what it means.
    io::println("#{map::len(map::remove(r, "zz"))}");

    // Numbers. `f64` is IEEE throughout: nothing here traps or throws.
    io::println("#{math::sqrt(9.0)} #{math::pow(2.0, 10.0)}");
    io::println("#{math::is_nan(math::sqrt(-1.0))} #{math::is_infinite(1.0 / 0.0)}");
    io::println("#{math::floor(1.7)} #{math::ceil(1.2)} #{math::round(1.5)}");
    io::println("#{math::abs(-2.5)} #{math::abs_int(-7)}");
    io::println("#{math::to_f64(3)} #{math::to_int(3.9)}");
}
