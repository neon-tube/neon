// `|>` associates left, so a chain reads as a pipeline: `x |> f() |> g()` is
// `g(f(x))`, with the stages running in written order.

use std::io;
use std::string;

fn double(x: i64) -> i64 {
    io::println("double");
    x * 2
}

fn add(x: i64, n: i64) -> i64 {
    io::println("add");
    x + n
}

fn main() {
    // g(f(x)), not f(g(x)): 1 doubled is 2, plus 3 is 5, doubled is 10.
    io::println(string::int_to_str(1 |> double() |> add(3) |> double()));

    // A pipeline changing type as it goes.
    io::println(21 |> double() |> string::int_to_str());
}
