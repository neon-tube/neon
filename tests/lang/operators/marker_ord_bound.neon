// `marker Ord` — a bound with no methods, satisfied by a compiler rule rather than
// by an impl. It is how a generic says "my parameter can be ordered": `<` is a
// structural primitive (docs/decisions.md), so ordering is a property a type *has*
// by construction, not one it opts into.
//
// Without the bound, `a < b` on an abstract `T` is refused — a generic body is
// checked once, with nothing concrete to test. With it, the body is allowed and each
// call site checks the type `T` was actually bound to.
//
// Order is infectious, and the bound threads through that recursion: `Box[T]` is
// ordered exactly because `T` is bound here. Ask without that context and it is not.

use std::io;

record Box[T] { v: T }

fn max[T](a: T, b: T) -> T where T: Ord {
    if a < b { b } else { a }
}

// A bound parameter stays ordered underneath a container, so `Box[T]` satisfies the
// bound `max` asks for.
fn wider[T](a: Box[T], b: Box[T]) -> Box[T] where T: Ord {
    max(a, b)
}

fn main() {
    io::println("#{max(1, 2)}");
    io::println(max("a", "b"));
    io::println("#{max(1.5, 0.5)}");

    // A record is ordered when its fields are, so it satisfies the bound too.
    io::println("#{max(Box { v: 3 }, Box { v: 9 }).v}");
    io::println("#{wider(Box { v: 4 }, Box { v: 8 }).v}");

    // And a list, which is ordered because its element is.
    io::println("#{max([1, 2], [1, 3])[1]}");
}
