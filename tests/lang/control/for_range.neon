// `for i in range(a, b)` counts from `a` up to but not including `b` — the
// half-open convention, so `range(0, n)` yields n values and `range(a, a)`
// yields none.
//
// Whether a range materializes a list or is iterated lazily is an
// implementation choice and deliberately not observable here.

use std::io;
use std::string;

fn show(v: i64) { io::println(string::int_to_str(v)); }

fn main() {
    for i in range(0, 3) {
        show(i);
    }

    // Half-open: empty when the bounds meet, and empty when they cross.
    for i in range(2, 2) {
        io::println("never");
    }
    for i in range(2, 1) {
        io::println("never");
    }

    // Negative bounds count up all the same.
    for i in range(-2, 1) {
        show(i);
    }

    // n values, so the sum of 0..n-1 comes out right.
    let sum = 0;
    for i in range(0, 5) {
        sum = sum + i;
    }
    show(sum);
}
