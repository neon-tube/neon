// A lambda is `(params) => body`. Parameter types may be written or inferred
// from the expected type; the body is a single expression, and a block is an
// expression. A lambda that captures nothing is still a first-class value.

use std::io;
use std::string;

fn apply(x: i64, f: (i64) -> i64) -> i64 { f(x) }

fn main() {
    // Explicitly typed parameter.
    let inc = (x: i64) => x + 1;
    io::println(to_string(inc(4)));

    // Parameter type inferred from the annotation on the binding.
    let dbl: (i64) -> i64 = (x) => x * 2;
    io::println(to_string(dbl(4)));

    // Inferred from the parameter it is passed as.
    io::println(to_string(apply(4, (x) => x - 1)));

    // Zero parameters, and more than one.
    let five = () => 5;
    io::println(to_string(five()));
    let sum = (a: i64, b: i64) => a + b;
    io::println(to_string(sum(2, 3)));

    // A block body; the last expression is the value.
    let squared_plus = (x: i64) => {
        let sq = x * x;
        sq + 1
    };
    io::println(to_string(squared_plus(3)));

    // Applied immediately.
    io::println(to_string(((x: i64) => x * 10)(4)));
}
