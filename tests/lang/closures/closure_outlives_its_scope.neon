// A closure that captures a local and is RETURNED keeps that value alive: the
// capture is by value, so the closure owns its copy and the frame it was born
// in is free to go. Two closures made from the same factory hold independent
// captures.

use std::io;
use std::string;

fn adder(n: i64) -> (i64) -> i64 {
    (x: i64) => x + n
}

fn prefixer(p: str) -> (i64) -> str {
    (x: i64) => string::concat(p, to_string(x))
}

fn main() {
    let add2 = adder(2);
    let add10 = adder(10);

    io::println(to_string(add2(1)));
    io::println(to_string(add10(1)));
    // The first closure is unaffected by the second's existence.
    io::println(to_string(add2(1)));

    let tag = prefixer("v=");
    io::println(tag(5));

    // A closure captured by another closure, escaping together.
    let twice = (f: (i64) -> i64) => (x: i64) => f(f(x));
    let add4 = twice(add2);
    io::println(to_string(add4(0)));
}
