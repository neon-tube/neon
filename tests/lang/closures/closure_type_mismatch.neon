//@ compile-fail
//@ error-contains: str
//
// Closure types are checked structurally, parameter by parameter and on the
// return: a `(str) -> str` is not a `(i64) -> i64`, and passing one where the
// other is expected is rejected at the call site, not at the eventual call.

use std::io;
use std::string;

fn apply(x: i64, f: (i64) -> i64) -> i64 { f(x) }

fn main() {
    let shout: (str) -> str = (s) => string::concat(s, "!");
    io::println(to_string(apply(5, shout)));
}
