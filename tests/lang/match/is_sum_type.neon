// `enum` does not exist. A sum type is a union of records, and `is Type` arms
// take it apart. This is the shape every sum type in Neon has:
//
//     record Circle { r: i64 }
//     record Rect { w: i64, h: i64 }
//     type Shape = Circle | Rect
//
// Each arm narrows the scrutinee to that member, so `s.r` is legal in the
// `is Circle` arm and nowhere else. The match is exhaustive with no `_` because
// the arms cover the whole union — the variant *set* is sealed by the alias.

use std::io;
use std::string;

record Circle { r: i64 }
record Rect { w: i64, h: i64 }
record Point {}

type Shape = Circle | Rect | Point

fn name(s: Shape) -> str {
    match s {
        is Circle => "circle",
        is Rect => "rect",
        is Point => "point",
    }
}

// Narrowing gives each arm access to that member's fields.
fn area(s: Shape) -> i64 {
    match s {
        is Circle => s.r * s.r * 3,
        is Rect => s.w * s.h,
        is Point => 0,
    }
}

fn main() {
    io::println(name(Circle { r: 2 }));
    io::println(name(Rect { w: 3, h: 4 }));
    io::println(name(Point {}));

    io::println(to_string(area(Circle { r: 2 })));
    io::println(to_string(area(Rect { w: 3, h: 4 })));
    io::println(to_string(area(Point {})));

    // A unit record stays nominal: it is a member of Shape by name, and an
    // unrelated empty record is not a Shape. There is no structural hole.
    io::println(name(Point {}));
}
