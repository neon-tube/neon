//@ compile-fail
//@ error-contains: area
//
// A protocol method is only callable on a type that implements it. `Tri` has no
// `Shape` impl, so `area(Tri { ... })` has zero candidates — an error at the
// call, with no silent fallback to another type's impl.

use std::io;
use std::string;

protocol Shape for T { fn area(s: T) -> i64 }

record Sq { side: i64 }
record Tri { base: i64, height: i64 }

impl Shape for Sq { fn area(s: Sq) -> i64 { s.side * s.side } }

fn main() {
    io::println(to_string(area(Tri { base: 2, height: 3 })));
}
