//@ compile-fail
//@ error-contains: is sealed

// The sealed assertion ban fires through a generic instantiation. A signature records
// which of its own type parameters the body asserts with `as!`; each call site then
// checks the types those parameters are bound to. Binding one to a type with a sealed
// leaf foreign to the CALLEE's module is rejected, because after monomorphisation the
// body is literally `a as! vault::Secret` running in the callee's module — the exact
// spelling the ban rejects when written directly.
//
// Direct spelling only: a wrapper that forwards to another generic's `as!` is not
// traced. That depth stays sound at run time regardless — the cast compiles to the
// tag check, so only a value the owner genuinely constructed can be asserted, which
// the holder could equally have recovered with `as?`.

use std::io;

internal mod vault {
    sealed record Secret { code: i64 }
    fn seal(n: i64) -> Secret { Secret { code: n } }
    fn value(s: Secret) -> i64 { s.code }
}

fn launder[T](a: any) -> T {
    a as! T
}

fn main() {
    let a: any = vault::seal(9);
    let s = launder[vault::Secret](a);
    io::println(to_string(vault::value(s)));
}
