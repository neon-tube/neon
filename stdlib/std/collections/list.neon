// Immutable lists. Every operation returns a new list; these are values, which is
// what makes their generic argument covariant. `rc == 1` reuse makes the copy free
// when the input is uniquely owned.

@native("neon_list_new") fn new[T]() -> List[T]
// Preallocate capacity for `n` elements to avoid regrowth while building.
@native("neon_list_new_with_capacity") fn new_with_capacity[T](n: i64) -> List[T]
@native("neon_list_len") fn len[T](xs: List[T]) -> i64

// The unchecked primitives. A native cannot build the tagged result a throwing function
// returns, nor construct an `IndexError` — both are program-specific layouts codegen owns.
// So the native does the unchecked operation and the check lives here, in the language,
// where the error record is declared and its message can name the offending index.
internal mod raw {
    @native("neon_list_set") fn set_unchecked[T](xs: List[T], i: i64, v: T) -> List[T]
}

fn get[T](xs: List[T], i: i64) throws IndexError -> T {
    if i < 0 or i >= len(xs) {
        throw IndexError { message: "index #{i} out of range for length #{len(xs)}" };
    }
    xs[i]
}

fn set[T](xs: List[T], i: i64, v: T) throws IndexError -> List[T] {
    if i < 0 or i >= len(xs) {
        throw IndexError { message: "index #{i} out of range for length #{len(xs)}" };
    }
    raw::set_unchecked(xs, i, v)
}
@native("neon_list_push") fn push[T](xs: List[T], v: T) -> List[T]
@native("neon_list_concat") fn concat[T](a: List[T], b: List[T]) -> List[T]

// ---- sorting ----
//
// Merge sort, and deliberately so. A comparator can lie -- `sort` on a list holding
// NaN is the documented case, since NaN compares false against everything -- and an
// introsort-style algorithm can read past its bounds when that happens. Merging only
// ever advances an index it has already bounds-checked, so a lying comparator costs
// you a wrong order and nothing else.
//
// Stable: `merge` takes from the left whenever the two are equal, which is why the
// test is `cmp(b, a) is :lt` rather than `cmp(a, b) is :gt`.

fn sort[T](xs: List[T]) -> List[T] where T: Ord {
    sort_by(xs, (a: T, b: T) => if a < b { :lt } else if b < a { :gt } else { :eq })
}

fn sort_by[T](xs: List[T], cmp: (T, T) -> Ordering) -> List[T] {
    let n = len(xs);
    if n <= 1 {
        xs
    } else {
        let mid = n / 2;
        let left: List[T] = [];
        let right: List[T] = [];
        let i = 0;
        while i < mid {
            left = push(left, xs[i]);
            i = i + 1;
        };
        while i < n {
            right = push(right, xs[i]);
            i = i + 1;
        };
        merge(sort_by(left, cmp), sort_by(right, cmp), cmp)
    }
}

// Merge two lists that are each already sorted by `cmp`. `sort_by`'s inner loop, and
// useful on its own.
fn merge[T](a: List[T], b: List[T], cmp: (T, T) -> Ordering) -> List[T] {
    let out: List[T] = [];
    let i = 0;
    let j = 0;
    while i < len(a) and j < len(b) {
        if cmp(b[j], a[i]) is :lt {
            out = push(out, b[j]);
            j = j + 1;
        } else {
            out = push(out, a[i]);
            i = i + 1;
        };
    };
    while i < len(a) {
        out = push(out, a[i]);
        i = i + 1;
    };
    while j < len(b) {
        out = push(out, b[j]);
        j = j + 1;
    };
    out
}
